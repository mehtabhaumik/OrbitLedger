rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function workspaceRef(workspaceId) {
      return /databases/$(database)/documents/workspaces/$(workspaceId);
    }

    function ownsWorkspace(workspaceId) {
      return signedIn() &&
        exists(workspaceRef(workspaceId)) &&
        get(workspaceRef(workspaceId)).data.owner_uid == request.auth.uid;
    }

    function createsOwnWorkspace() {
      return signedIn() &&
        request.resource.data.owner_uid == request.auth.uid &&
        request.resource.data.owner_uid is string &&
        request.resource.data.business_name is string &&
        request.resource.data.currency is string &&
        request.resource.data.country_code is string;
    }

    function keepsWorkspaceOwner() {
      return signedIn() &&
        resource.data.owner_uid == request.auth.uid &&
        request.resource.data.owner_uid == resource.data.owner_uid;
    }

    function clientManagedWorkspaceCollection(collectionName) {
      return collectionName != 'subscription_checkouts' &&
        collectionName != 'subscription_events' &&
        collectionName != 'subscription_billing_email_requests' &&
        collectionName != 'subscription_renewal_changes' &&
        collectionName != 'subscription_billing_portal_sessions' &&
        collectionName != 'subscription_admin_queue' &&
        collectionName != 'subscription_renewal_audit';
    }

    match /workspaces/{workspaceId} {
      allow create: if createsOwnWorkspace();
      allow read: if signedIn() && resource.data.owner_uid == request.auth.uid;
      allow update: if keepsWorkspaceOwner();
      allow delete: if signedIn() && resource.data.owner_uid == request.auth.uid;

      match /{collectionName}/{recordId} {
        allow read, create, update, delete: if ownsWorkspace(workspaceId) &&
          clientManagedWorkspaceCollection(collectionName);
      }

      match /subscription_renewal_changes/{changeId} {
        allow read: if ownsWorkspace(workspaceId);
        allow create, update, delete: if false;
      }

      match /subscription_checkouts/{checkoutId} {
        allow read: if ownsWorkspace(workspaceId);
        allow create, update, delete: if false;
      }

      match /subscription_events/{eventId} {
        allow read: if ownsWorkspace(workspaceId);
        allow create, update, delete: if false;
      }

      match /subscription_billing_email_requests/{requestId} {
        allow read: if ownsWorkspace(workspaceId);
        allow create, update, delete: if false;
      }

      match /subscription_billing_portal_sessions/{sessionId} {
        allow read: if ownsWorkspace(workspaceId);
        allow create, update, delete: if false;
      }

      match /subscription_admin_queue/{queueId} {
        allow read: if ownsWorkspace(workspaceId);
        allow create, update, delete: if false;
      }

      match /subscription_renewal_audit/{auditId} {
        allow read: if ownsWorkspace(workspaceId);
        allow create, update, delete: if false;
      }
    }

    match /users/{userId}/subscription_entitlements/{workspaceId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    match /users/{userId}/subscription_entitlement_audit/{auditId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
