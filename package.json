{
  "name": "orbit-ledger-workspace",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.14.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/functions",
    "apps/mobile",
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run start --workspace @orbit-ledger/mobile",
    "start:dev-client": "npm run start:dev-client --workspace @orbit-ledger/mobile",
    "android": "npm run android --workspace @orbit-ledger/mobile",
    "android:local": "npm run android:local --workspace @orbit-ledger/mobile",
    "android:dev-client": "npm run android:dev-client --workspace @orbit-ledger/mobile",
    "ios": "npm run ios --workspace @orbit-ledger/mobile",
    "ios:local": "npm run ios:local --workspace @orbit-ledger/mobile",
    "ios:local:clear": "npm run ios:local:clear --workspace @orbit-ledger/mobile",
    "ios:dev-client": "npm run ios:dev-client --workspace @orbit-ledger/mobile",
    "web": "npm run dev --workspace @orbit-ledger/web",
    "mobile:web": "npm run web --workspace @orbit-ledger/mobile",
    "doctor": "npm run doctor --workspace @orbit-ledger/mobile",
    "brand:assets": "npm run brand:assets --workspace @orbit-ledger/mobile",
    "smoke:razorpay-checkout": "node scripts/razorpay-checkout-smoke.mjs",
    "smoke:razorpay-checkout:connected": "node scripts/razorpay-checkout-smoke.mjs --expect-connected",
    "typecheck": "npm run typecheck --workspace @orbit-ledger/contracts && npm run typecheck --workspace @orbit-ledger/core && npm run typecheck --workspace @orbit-ledger/ui && npm run typecheck --workspace @orbit-ledger/sync && npm run typecheck --workspace @orbit-ledger/mobile && npm run typecheck --workspace @orbit-ledger/web && npm run typecheck --workspace @orbit-ledger/functions",
    "test": "vitest run apps packages",
    "test:rules": "vitest run firebase/rules.test.ts",
    "audit:ci": "npm audit --audit-level=high"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "expo": "~54.0.34",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13"
  }
}
