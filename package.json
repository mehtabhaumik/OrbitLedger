{
  "name": "orbit-ledger-workspace",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "apps/mobile",
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run start --workspace @orbit-ledger/mobile",
    "start:dev-client": "npm run start:dev-client --workspace @orbit-ledger/mobile",
    "android": "npm run android --workspace @orbit-ledger/mobile",
    "android:local": "npm run android:local --workspace @orbit-ledger/mobile",
    "android:dev-client": "npm run android:dev-client --workspace @orbit-ledger/mobile",
    "ios": "npm run ios --workspace @orbit-ledger/mobile",
    "ios:local": "npm run ios:local --workspace @orbit-ledger/mobile",
    "ios:local:clear": "npm run ios:local:clear --workspace @orbit-ledger/mobile",
    "ios:dev-client": "npm run ios:dev-client --workspace @orbit-ledger/mobile",
    "web": "npm run dev --workspace @orbit-ledger/web",
    "mobile:web": "npm run web --workspace @orbit-ledger/mobile",
    "doctor": "npm run doctor --workspace @orbit-ledger/mobile",
    "brand:assets": "npm run brand:assets --workspace @orbit-ledger/mobile",
    "typecheck": "npm run typecheck --workspace @orbit-ledger/contracts && npm run typecheck --workspace @orbit-ledger/core && npm run typecheck --workspace @orbit-ledger/ui && npm run typecheck --workspace @orbit-ledger/sync && npm run typecheck --workspace @orbit-ledger/mobile && npm run typecheck --workspace @orbit-ledger/web"
  }
}
